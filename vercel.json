{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/.next",
  "installCommand": "cd web && npm install",
  "framework": "nextjs",
  "functions": {
    "api/main.py": {
      "runtime": "python3.12"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/main.py" }
  ]
}
